import <"core">  
import <"stdlib">  

using Core;  
using Console;
using Collections;

int globalVar1 = 444;
float globalVar2 = 444.0f;

// ----------------- 全局变量读写测试 ------------------

void test_global_var()
{
	Console::PrintLn("------- test globalvar -------");

	int result = globalVar1 + (int)globalVar2;
	Console::PrintLn("result:" + (string)result);
}

// ----------------- 寄存器溢出测试 ------------------

void test_reg_alloc()
{
	Console::PrintLn("------- test_reg_alloc -------");

	int v1 = 2;
	int v2 = 2;
	int v3 = 2;
	int v4 = 2;
	int v5 = 2;
	int v6 = 2;
	int v7 = 2;
	int v8 = 2;
	
	
	int rs = v1 + v8;
	rs += v2 + v7;
	rs += v3 + v6;
	rs += v4 + v5;
	Console::PrintLn("test!" + (string)rs);
}

// ----------------- 调用测试 ------------------

int sum(int x, int y, int z)
{
	return x + y - z;
}

class TestClass
{
	int Foo(int a){ return a + 1; }
}
void test_call()
{
	Console::PrintLn("------- test_call -------");

	int num1 = 1000;
	int num2 = 200;
	int num3 = 100;
	int num4 = sum(num1, num2, num3);
	Console::PrintLn("Calc:");
	Console::PrintLn((string)num4);


	TestClass obj = new TestClass();
	int rs = obj.Foo(123456);
	Console::PrintLn("TestClass.Foo result:" + (string)rs);
}

// ----------------- SizeOf ------------------

void test_sizeof()
{	Console::PrintLn("------- test sizeof -------");

	int sizeofint = sizeof(int);
	Console::PrintLn("sizeof(int):" + (string)sizeofint);
}

// ----------------- Dic ------------------
class OOO
{
	int value = 666;
	OOO(int v)
	{
		this.value = v;
	}
}
void test_dic()
{
	Console::PrintLn("------- test dic -------");

	OOO o1 = new OOO(123);
	OOO o2 = new OOO(123);
	OOO o3 = o2;
	Console::PrintLn("OOO o1 addr :" + (string)(hashof(o1)));
	Console::PrintLn("OOO o2 addr :" + (string)(hashof(o2)));
	Console::PrintLn("o1 o2 equal :" + (string)(o1 == o2));
	Console::PrintLn("o2 o3 equal :" + (string)(o2 == o3));
	Console::PrintLn("o1 ToString1::" + (string)(o1));
	Console::PrintLn("o1 ToString2::" + o1.ToString());

	
	HashMap<int, int> dict = new HashMap<int, int>();
	dict.Add(1, 10);
	int result = dict.Get(1);
	Console::PrintLn("Dic1 result:" + (string)result);
	
	var dict2 = new HashMap<string, string>();
	string strKey = "name";
	dict2.Add(strKey, "rew");
	string result2 = dict2.Get(strKey);
	Console::PrintLn("Dic2 result:" + result2);

	var dict3 = new HashMap<OOO, int>();
	OOO o = new OOO(123);
	dict3.Add(o, 123);
	int result3 = dict3.Get(o);
	Console::PrintLn("Dic3 result:" + (string)result3);


	ChainedHashMap<string, int> dict4 = new ChainedHashMap<string, int>();
	dict4.Add("num", 123456);
	int result4 = dict4.Get("num");
	Console::PrintLn("Dic4 result:" + (string)result4);
}

// ----------------- 位运算 -----------------
void test_bitwise()
{
	Console::PrintLn("------- test bitwise -------");

	int a = 5; // 0101
	int b = 3; // 0011
	int andResult = a & b; // 0001 -> 1
	int orResult =  a | b;  // 0111 -> 7
	int notResult = ~a;    // 1010 (取反) -> -6  
	Console::PrintLn("Bitwise AND: " + (string)andResult);
	Console::PrintLn("Bitwise OR: " + (string)orResult);
	Console::PrintLn("Bitwise NOT: " + (string)notResult);
}

// ----------------- RTTI ------------------
void test_rtti()
{
	Console::PrintLn("------- test rtti -------");

	var t1 = typeof(Core::Object);
	var t2 = typeof(List<int>);
	var t3 = typeof(int);
	int v1 = 111;
	List<int> v2 = null;

	var t4 = gettype(v1);
	var t5 = gettype(v2);

	Console::PrintLn("Type of Core::Object: " + t1.name);
	Console::PrintLn("Type of List<int>: " + t2.name);
	Console::PrintLn("Type of int: " + t3.name);
	Console::PrintLn("GetType v1: " + t4.name);
	Console::PrintLn("GetType v2: " + t5.name);
}

// ----------------- IO --------------------
void test_fileio()
{
	Console::PrintLn("------- test io -------");
	
	var path = "C:\\Users\\saus\\Desktop\\test_file.txt";
	IO::FileWriteAllText(path, "Hello World!");
	Console::PrintLn("File written:" + path);
}

// ----------------- Test-CTOR ------------------
void test_ctor()
{
	Console::PrintLn("------- test ctor-------");

	Console::PrintLn("Testing constructors:");
	AAA otest = new AAA();
	Console::PrintLn("otest:" + (string)otest.value);

	BBB otest2 = new BBB(999);
	Console::PrintLn("otest2:" + (string)otest2.value);
	BBB otest3 = new BBB("sss");
	Console::PrintLn("otest3:" + (string)otest3.value);
}
class AAA
{
	int value = 0;
	AAA()
	{
		Console::PrintLn("AAA default ctor called");
		this.value = 111;
	}
	AAA(int v)
	{
		this.value = v;
	}
}
class BBB : AAA
{
	BBB(int v)
	{
		Console::PrintLn("BBB ctor called with value:" + (string)v);
	}
	BBB(string aaa)
	{
	}
}
// ----------------- Test-DTOR -------------
void test_dtor()
{
	Console::PrintLn("------- dtor -------");

	own CCC otest = new CCC();
}

class DDD
{
	~DDD()
	{
		Console::PrintLn("DDD destructor called!");
	}
}
class CCC
{
	own DDD fieldd = new DDD();
	~CCC()
	{
		Console::PrintLn("CCC destructor called!");
	}
}


// ----------------- Main ------------------
void main()
{
	float32 s = default(float32);
	test_global_var();
	test_reg_alloc();
	test_call();
	test_sizeof();
	test_dic();
	test_bitwise();
	test_rtti();
	test_fileio();
	test_ctor();
	test_dtor();

	Console::PrintLn("Test finished!");
	Console::ReadLn();
}



