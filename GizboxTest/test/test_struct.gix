import <"core">  
import <"stdlib">  

using Core;  
using Console;
using Collections;


struct Pair
{
	int a = 0;
	int b = 0;
}

namespace Pair
{
	Pair Create(int a, int b)
	{
		Pair p = default(Pair);
		p.a = a;
		p.b = b;
		return p;
	}
	Pair operator add(Pair p1, Pair p2)
	{
		Pair result = default(Pair);
		result.a = p1.a + p2.a;
		result.b = p1.b + p2.b;
		return result;
	}
}


struct BigData
{
	long x = 0L;
	long y = 0L;
	long z = 0L;
}
namespace BigData
{
	BigData Create(long x, long y, long z)
	{
		BigData d = default(BigData);
		d.x = x;
		d.y = y;
		d.z = z;
		return d;
	}
}

struct Wrapper
{
	Pair p = default(Pair);
	int n = 0;
}

Pair MakePair(int a, int b)
{
	Pair p = default(Pair);
	p.a = a;
	p.b = b;
	return p;
}

int SumPair(Pair p)
{
	return p.a + p.b;
}

BigData MakeBig(long seed)
{
	BigData d = default(BigData);
	d.x = seed;
	d.y = seed + 1L;
	d.z = seed + 2L;
	return d;
}

long SumBig(BigData d)
{
	return d.x + d.y + d.z;
}

BigData ForwardBig(BigData d)
{
	return d;
}

void test_struct_small()
{
	Console::PrintLn("---- test_struct_small---");
	
	Console::PrintLn("1");
	Pair p1 = default(Pair);
	p1.a = 10;
	p1.b = 20;
	
	Console::PrintLn("2");

	Pair p2 = p1;
	p2.a = p2.a + 1;
	
	Console::PrintLn("3");

	int s1 = SumPair(p1);
	int s2 = SumPair(p2);
	
	Console::PrintLn("4");

	Console::PrintLn("Pair s1=" + (string)s1 + "  Pair s2=" + (string)s2);
	Console::PrintLn("Pair s1=" + (string)s1);
	Console::PrintLn("Pair s2=" + (string)s2);
	
	Console::PrintLn("5");

	Pair p3 = MakePair(3, 4);
	Console::PrintLn("Pair make=" + (string)SumPair(p3));
}

void test_struct_nested()
{
	Console::PrintLn("---- test_struct_nested ---");

	Wrapper w = default(Wrapper);
	w.p.a = 5;
	w.p.b = 6;
	w.n = 100;
	
	Console::PrintLn("w.p.a=" + (string)w.p.a);
	Console::PrintLn("w.p.b=" + (string)w.p.b);
	Console::PrintLn("w.n=" + (string)w.n);

	int sum = w.p.a + w.p.b + w.n;
	Console::PrintLn("Wrapper sum=" + (string)sum);
}

void test_struct_big()
{
	Console::PrintLn("---- test_struct_big ---");

	BigData d1 = default(BigData);
	d1.x = 100L;
	d1.y = 200L;
	d1.z = 300L;

	BigData d2 = d1;

	long s1 = SumBig(d1);
	long s2 = SumBig(d2);
	Console::PrintLn("Big s1=" + (string)s1 + " s2=" + (string)s2);

	BigData d3 = MakeBig(1000L);
	Console::PrintLn("make Big sum=" + (string)SumBig(d3));

	BigData d4 = ForwardBig(d3);
	Console::PrintLn("forward Big sum=" + (string)SumBig(d4));
}

void test_ref_param()
{
	int a = 234;
	AddOneRef(a);
	Console::PrintLn("a=" + (string)a);


	Pair p = default(Pair);
	PairAddTwoRef(p);
	Console::PrintLn("p.a=" + (string)p.a + " p.b=" + (string)p.b);

	Pair p2 = default(Pair);
	PairAddTwo(p2);
	Console::PrintLn("p2.a=" + (string)p2.a + " p2.b=" + (string)p2.b);

	BigData d = default(BigData);
	BigAddTwoRef(d);
	long sumBig = SumBig(d);
	Console::PrintLn("d sum =" + (string)sumBig);

	BigData d2 = default(BigData);
	BigAddTwo(d2);
	sumBig = SumBig(d2);
	Console::PrintLn("d2 sum =" + (string)sumBig);

	BigData d3 = BigData::Create(10L, 20L, 30L);
	Console::PrintLn("d3 sum =" + (string)SumBig(d3));

	BigData d4 = { 11L, 22L, 33L };
	Console::PrintLn("d4 sum =" + (string)SumBig(d4));
}
void AddOneRef(int& x)
{
	int newx = x + 1;
	x = newx;
}
void BigAddTwo(BigData d)
{
	d.x = d.x + 2L;
	d.y = d.y + 2L;
	d.z = d.z + 2L;
}
void PairAddTwo(Pair p)
{
	p.a = p.a + 2;
	p.b = p.b + 2;
}
void BigAddTwoRef(BigData& d)
{
	d.x = d.x + 2L;
	d.y = d.y + 2L;
	d.z = d.z + 2L;
}
void PairAddTwoRef(Pair& p)
{
	p.a = p.a + 2;
	p.b = p.b + 2;
}


void test_size()
{
	int sizePair = sizeof(Pair);
	int sizeBigData = sizeof(BigData);

	Console::PrintLn("sizeof Pair=" + (string)sizePair);
	Console::PrintLn("sizeof BigData=" + (string)sizeBigData);
}



void test_operator()
{
	Pair a = Pair::Create(1, 2);
	Pair b = Pair::Create(3, 4);
	Pair c = a + b;
	Console::PrintLn("pair add result =" + (string)c.a + "," + (string)c.b);
}

void main()
{
	test_struct_small();
	test_struct_nested();
	test_struct_big();
	test_ref_param();
	test_size();
	test_operator();

	Console::PrintLn("Test finished!");
	Console::ReadLn();
}