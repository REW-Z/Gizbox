import <"core">  
import <"stdlib">  

using Core;  
using Console;
using Collections;

int and_right_hits = 0;
int or_right_hits = 0;

bool LeftFalse()
{
	return false;
}

bool LeftTrue()
{
	return true;
}

bool RightOfAnd()
{
	and_right_hits++;
	Console::PrintLn("Error:right-hits");
	return true;
}

bool RightOfOr()
{
	or_right_hits++;
	Console::PrintLn("Error:right-hits");
	return false;
}

void test_switch(int value)
{
	switch(value)
	{
	    case 1:
			Console::PrintLn("case 1");
			break;
	    case 2:
			Console::PrintLn("case 2");
			break;
	    case 3:
			Console::PrintLn("case 3");
			break;
	    default:
			Console::PrintLn("case default");
			break;
	}
}

void main()
{
	if(LeftFalse() && RightOfAnd())
	{
		Console::PrintLn("FAIL: LeftFalse() && RightOfAnd() should be false");
	}
	else
	{
		if(and_right_hits == 0)
		{
			Console::PrintLn("SUCCESS: &&");
		}
		else
		{
			Console::PrintLn("FAIL: &&");
		}
	}

	if(LeftTrue() || RightOfOr())
	{
		if(or_right_hits == 0)
		{
			Console::PrintLn("SUCCESS: ||");
		}
		else
		{
			Console::PrintLn("FAIL: ||");
		}
	}
	else
	{
		Console::PrintLn("FAIL: LeftTrue() || RightOfOr() should be true");
	}


	int aaa = 2;
	test_switch(aaa);
	int bbb = 444;
	test_switch(bbb);


	Console::PrintLn("Test finished!");
	Console::ReadLn();
}