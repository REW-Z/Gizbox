import <"core">  
import <"stdlib">  

using Core;  
using Console;
using Collections;

int and_right_hits = 0;
int or_right_hits = 0;

bool LeftFalse()
{
	return false;
}

bool LeftTrue()
{
	return true;
}

bool RightOfAnd()
{
	and_right_hits++;
	Console::PrintLn("Error:right-hits");
	return true;
}

bool RightOfOr()
{
	or_right_hits++;
	Console::PrintLn("Error:right-hits");
	return false;
}

void test_switch(int value)
{
	switch(value)
	{
	    case 1:
			Console::PrintLn("case 1");
			break;
	    case 99:
			Console::PrintLn("case 99");
			break;
	    case 7:
			Console::PrintLn("case 7");
			break;
	    case 2:
			Console::PrintLn("case 2");
			break;
	    case 3:
			Console::PrintLn("case 3");
			break;
	    case 8:
			Console::PrintLn("case 8");
			break;
	    default:
			Console::PrintLn("case default");
			break;
	}
}

void main()
{
	if(LeftFalse() && RightOfAnd())
	{
		Console::PrintLn("FAIL: LeftFalse() && RightOfAnd() should be false");
	}
	else
	{
		if(and_right_hits == 0)
		{
			Console::PrintLn("SUCCESS: &&");
		}
		else
		{
			Console::PrintLn("FAIL: &&");
		}
	}

	if(LeftTrue() || RightOfOr())
	{
		if(or_right_hits == 0)
		{
			Console::PrintLn("SUCCESS: ||");
		}
		else
		{
			Console::PrintLn("FAIL: ||");
		}
	}
	else
	{
		Console::PrintLn("FAIL: LeftTrue() || RightOfOr() should be true");
	}


	test_switch(1);
	test_switch(2);
	test_switch(3);
	test_switch(4);
	test_switch(5);
	test_switch(6);
	test_switch(7);
	test_switch(8);
	test_switch(9);
	test_switch(99);

	char ccc = 'c';
	switch(ccc)
	{
		case 'a':
			Console::PrintLn("case a");
			break;
		case 'b':
			Console::PrintLn("case b");
			break;
		case 'c':
			Console::PrintLn("case c");
			break;
		default:
			Console::PrintLn("case default");
			break;
	}


	Console::PrintLn("Test finished!");
	Console::ReadLn();
}