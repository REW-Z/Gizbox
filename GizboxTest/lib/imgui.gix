extern void Gizbox_ImGui_SetNextWindowSize(ImVec2 size, int cond);

extern void Gizbox_ImGui_SetDisplaySize(ImVec2 size, int cond);

extern int Gizbox_ImGui_Begin(string name, int flags);
extern void Gizbox_ImGui_End();

extern int Gizbox_ImGui_BeginChild(string str_id, ImVec2 size, int child_flags, int window_flags);
extern void Gizbox_ImGui_EndChild();

