import <"core">

using ImGui;

struct ImVec2
{
    float x = 0.0f;
    float y = 0.0f;
}

struct ImVec4
{
    float x = 0.0f;
    float y = 0.0f;
    float z = 0.0f;
    float w = 0.0f;
}

struct ImGuiBoolResultRaw
{
    int changed = 0;
    int value = 0;
}

struct ImGuiFloatResultRaw
{
    int changed = 0;
    float value = 0.0f;
}

struct ImGuiIntResultRaw
{
    int changed = 0;
    int value = 0;
}

extern ulong Gizbox_ImGui_CreateContext();
extern void Gizbox_ImGui_DestroyContext(ulong ctx);
extern ulong Gizbox_ImGui_GetCurrentContext();
extern void Gizbox_ImGui_SetCurrentContext(ulong ctx);
